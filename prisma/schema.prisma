datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  currency      String    @default("USD")
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  categories    Category[]
  notificationRules NotificationRule[]
  hasSeenTutorial Boolean @default(false)
  createdAt     DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  name           String
  price          Float
  currency       String   @default("USD")
  
  frequencyValue Int      @default(1)
  frequencyUnit  String   @default("Monthly")

  nextRenewalDate DateTime
  category       String?
  
  description    String?
  website        String?
  logoUrl        String?
  
  isShared       Boolean  @default(false)
  sharedCount    Int      @default(1)

  status         String   @default("Active")
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationRules NotificationRule[]
}

model Category {
  id     String @id @default(cuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
}

model NotificationRule {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  value       Int
  unit        String
  type        String   @default("SPECIFIC") 
  
  subscriptions Subscription[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
